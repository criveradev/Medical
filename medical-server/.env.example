# ═══════════════════════════════════════════════════════════════
# .env.example — Variables de entorno (medical-server)
# Copiar a .env y completar con valores reales. No subir el .env al repo.
# ═══════════════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Frontend permitido por CORS
CLIENT_URL=http://localhost:4200

# ── Base de datos (MongoDB) ────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/medical_db

# ── Caché (Redis) — opcional, degrada a MongoDB si no está ─────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Autenticación (JWT) — usar claves largas y aleatorias ──────
# JWT — genera secretos con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura
JWT_REFRESH_SECRET=cambia_esto_por_otra_clave_muy_larga_diferente
JWT_EXPIRES=8h

# ── Email (SMTP) ───────────────────────────────────────────────
# En desarrollo local sirve iCloud/Gmail. En la nube (Render, etc.) iCloud suele
# dar "Connection timeout": usa un proveedor transaccional como Resend.
#
# Resend (recomendado en producción):
#   EMAIL_FROM=tu_correo_verificado@dominio.com
#   RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
#
# iCloud (local): EMAIL_HOST=smtp.mail.me.com · EMAIL_PASS = app-specific password
# Gmail (local):  EMAIL_HOST=smtp.gmail.com · EMAIL_PASS = App Password de 16 chars
#
# EMAIL_FROM es opcional: si no se define, se usa EMAIL_USER como remitente.
EMAIL_HOST=smtp.mail.me.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@icloud.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=

# IMPORTANTE en hosts que bloquean SMTP (Render free, Railway free/hobby):
# define RESEND_API_KEY y el envío usará la API HTTP de Resend (puerto 443, nunca
# bloqueado) en vez de SMTP. Si se define, EMAIL_HOST/PORT/USER/PASS se ignoran
# y EMAIL_FROM pasa a ser obligatorio.
RESEND_API_KEY=

# ── Almacenamiento de archivos (Cloudinary) ────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Monitoreo de errores (Sentry) ──────────────────────────────
SENTRY_DSN=https://TU_DSN_AQUI
