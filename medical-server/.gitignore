# ═══════════════════════════════════════════════════════════════
# .gitignore — Archivos a ignorar en git
# ═══════════════════════════════════════════════════════════════

# Dependencias
node_modules/

# Variables de entorno (nunca subir al repositorio)
.env
.env.development
.env.production

# Logs generados por Winston
logs/

# Archivos subidos por usuarios
uploads/

# Sistema operativo
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Cobertura de tests
coverage/

# Archivos de prueba temporales
reporte.pdf
reporte.xlsx
response.json
postman.js
